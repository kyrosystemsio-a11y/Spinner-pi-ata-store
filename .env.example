# The real deployed origin (no trailing slash). Used for metadataBase, OG/Twitter
# tags, sitemap.xml, and robots.ts. Falls back to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=

# Required for /cart checkout to work. Use a TEST MODE secret key to start
# (https://dashboard.stripe.com/test/apikeys). Without this, checkout returns
# a 503 instead of crashing.
STRIPE_SECRET_KEY=
# Required for the Stripe webhook (order-completed logging) to verify requests.
# Create the webhook endpoint at https://dashboard.stripe.com/test/webhooks
# pointing to <your-domain>/api/webhooks/stripe, subscribed to
# checkout.session.completed, then paste its signing secret here.
STRIPE_WEBHOOK_SECRET=

# Required for the /contact-us form to actually send email.
# Sign up at https://resend.com to get an API key.
RESEND_API_KEY=
# Inbox that contact form submissions should be delivered to.
CONTACT_TO_EMAIL=
# Optional: verified sending address (defaults to Resend's onboarding sender).
CONTACT_FROM_EMAIL=
